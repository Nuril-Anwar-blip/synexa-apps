generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  pasien
  apoteker
  admin
}

enum Period {
  Pagi
  Siang
  Sore
  Malam
}

model User {
  id                String   @id @default(uuid()) @db.Uuid
  email             String?  @unique
  password          String   @default("")
  full_name         String   @default("")
  phone_number      String   @default("")
  age               Int      @default(0)
  height            Float    @default(0.0)
  weight            Float    @default(0.0)
  gender            String   @default("male")
  medical_history   Json     @default("[]")
  drug_allergy      Json     @default("[]")
  emergency_contact Json     @default("{}")
  photo_url         String?
  role              Role     @default(pasien)
  created_at        DateTime @default(now())

  // Relationships
  admin                Admin?
  posts                Post[]
  comments             Comment[]
  likes                Like[]
  medication_reminders MedicationReminder[]
  pairings             Pairing[]
  sensor_data          SensorData[]
  emergency_logs       EmergencyLog[]
  health_logs          HealthLog[]
  notifications        Notification[]
  rehab_exercise_logs  RehabExerciseLog[]
  rehab_quiz_attempts  RehabQuizAttempt[]
  rehab_user_progress  RehabUserProgress?

  // Chat relationships
  patient_rooms    ChatRoom[] @relation("PatientRooms")
  pharmacist_rooms ChatRoom[] @relation("PharmacistRooms")
  messages         Message[]

  @@map("users")
}

model Admin {
  user_id    String   @id @db.Uuid
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("admins")
}

model AppConfig {
  key         String   @id
  value       String
  description String?
  updated_at  DateTime @default(now()) @updatedAt

  @@map("app_config")
}

model EducationContent {
  id         String   @id @default(uuid()) @db.Uuid
  title      String
  category   String?
  content    String?
  media_url  String?
  created_at DateTime @default(now())

  @@map("education_contents")
}

model EmergencyLog {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid
  location_lat  Float?
  location_long Float?
  status        String?  @default("active")
  triggered_at  DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("emergency_logs")
}

model HealthLog {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String?  @db.Uuid
  log_type        String
  value_systolic  Int?
  value_diastolic Int?
  value_numeric   Float?
  note            String?
  recorded_at     DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("health_logs")
}

model MedicationMaster {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  default_dose String?
  category     String?
  is_common    Boolean? @default(true)

  @@map("medication_master")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  title      String
  body       String
  type       String?
  is_read    Boolean? @default(false)
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

model RehabPhase {
  id                     Int      @id
  name                   String
  duration_weeks_min     Int?
  duration_weeks_max     Int?
  target_description     String?
  daily_duration_minutes String?
  pass_score_min         Int?
  min_consecutive_days   Int?
  safety_notes           String[]

  exercises      RehabExercise[]
  quiz_questions RehabQuizQuestion[]
  quiz_attempts  RehabQuizAttempt[]
  user_progress  RehabUserProgress[]

  @@map("rehab_phases")
}

model RehabExercise {
  id               String   @id @default(uuid()) @db.Uuid
  phase_id         Int?
  time_category    String?
  name             String
  instructions     String[]
  duration_text    String?
  duration_seconds Int?
  is_repetition    Boolean? @default(false)
  media_url        String?

  phase         RehabPhase?        @relation(fields: [phase_id], references: [id])
  exercise_logs RehabExerciseLog[]

  @@map("rehab_exercises")
}

model RehabExerciseLog {
  id                      String   @id @default(uuid()) @db.Uuid
  user_id                 String?  @db.Uuid
  exercise_id             String?  @db.Uuid
  duration_actual_seconds Int?
  is_aborted              Boolean? @default(false)
  abort_reason            String?
  completed_at            DateTime @default(now())

  user     User?          @relation(fields: [user_id], references: [id])
  exercise RehabExercise? @relation(fields: [exercise_id], references: [id])

  @@map("rehab_exercise_logs")
}

model RehabQuizQuestion {
  id            String   @id @default(uuid()) @db.Uuid
  from_phase_id Int?
  question_text String
  is_critical   Boolean? @default(false)
  order_index   Int?

  phase RehabPhase? @relation(fields: [from_phase_id], references: [id])

  @@map("rehab_quiz_questions")
}

model RehabQuizAttempt {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid
  from_phase_id Int?
  score         Int?
  passed        Boolean?
  responses     Json?
  created_at    DateTime @default(now())

  user  User?       @relation(fields: [user_id], references: [id])
  phase RehabPhase? @relation(fields: [from_phase_id], references: [id])

  @@map("rehab_quiz_attempts")
}

model RehabUserProgress {
  user_id          String    @id @db.Uuid
  current_phase_id Int?      @default(1)
  phase_started_at DateTime? @default(now())
  last_quiz_at     DateTime?
  streak_count     Int?      @default(0)

  user  User        @relation(fields: [user_id], references: [id])
  phase RehabPhase? @relation(fields: [current_phase_id], references: [id])

  @@map("rehab_user_progress")
}

model ChatRoom {
  id            String   @id @default(uuid()) @db.Uuid
  patient_id    String   @db.Uuid
  pharmacist_id String   @db.Uuid
  created_at    DateTime @default(now())

  patient    User      @relation("PatientRooms", fields: [patient_id], references: [id])
  pharmacist User      @relation("PharmacistRooms", fields: [pharmacist_id], references: [id])
  messages   Message[]

  @@map("chat_rooms")
}

model Comment {
  id         String   @id @default(uuid()) @db.Uuid
  post_id    String?  @db.Uuid
  user_id    String?  @db.Uuid
  content    String?
  created_at DateTime @default(now())

  post Post? @relation(fields: [post_id], references: [id])
  user User? @relation(fields: [user_id], references: [id])

  @@map("comments")
}

model Like {
  id         String   @id @default(uuid()) @db.Uuid
  post_id    String?  @db.Uuid
  user_id    String?  @db.Uuid
  created_at DateTime @default(now())

  post Post? @relation(fields: [post_id], references: [id])
  user User? @relation(fields: [user_id], references: [id])

  @@map("likes")
}

model MedicationReminder {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  name          String
  dose          String?
  note          String?
  time          DateTime @db.Time
  period        Period
  taken         Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt
  is_active     Boolean  @default(true)
  current_stock Int      @default(0)
  total_stock   Int      @default(0)

  user User @relation(fields: [user_id], references: [id])

  @@map("medication_reminders")
}

model Message {
  id         String   @id @default(uuid()) @db.Uuid
  room_id    String   @db.Uuid
  sender_id  String   @db.Uuid
  content    String
  metadata   Json?
  created_at DateTime @default(now())

  room   ChatRoom @relation(fields: [room_id], references: [id])
  sender User     @relation(fields: [sender_id], references: [id])

  @@map("messages")
}

model Pairing {
  id            String   @id @default(uuid()) @db.Uuid
  pairing_code  String?  @unique
  refresh_token String?
  user_id       String?  @db.Uuid
  created_at    DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("pairings")
}

model PharmacistInvitation {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  description String?
  created_by  String?   @db.Uuid
  is_used     Boolean   @default(false)
  used_by     String?   @db.Uuid
  used_at     DateTime?
  expires_at  DateTime?
  created_at  DateTime  @default(now())

  @@map("pharmacist_invitations")
}

model Post {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String?  @db.Uuid
  content       String?
  media_url     String?
  media_type    String?
  like_count    Int      @default(0)
  comment_count Int      @default(0)
  created_at    DateTime @default(now())

  user     User?     @relation(fields: [user_id], references: [id])
  comments Comment[]
  likes    Like[]

  @@map("posts")
}

model SensorData {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  type       String
  value      Json?
  heart_rate Int?
  latitude   Float?
  longitude  Float?
  timestamp  DateTime @default(now())
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@map("sensor_data")
}
